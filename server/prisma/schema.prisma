generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  category   String
  price      Float

  createdAt  DateTime
  updatedAt  DateTime

  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@index([category, createdAt(sort: Desc), id(sort: Desc)])
}